<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.wu.web.mapper.BankMapper">
    <resultMap id="BaseResultMap" type="com.wu.web.model.Bank">
        <id column="id" property="id" jdbcType="INTEGER"/>
        <result column="bankcode" property="bankcode" jdbcType="VARCHAR"/>
        <result column="bankname" property="bankname" jdbcType="VARCHAR"/>
    </resultMap>

    <select id="getAllBanks" resultMap="BaseResultMap">
        select * from bank;
    </select>

    <insert id="addBank" parameterType="com.wu.web.model.Bank">
        insert into bank (bankcode, bankname)
        values(#{bankcode}, #{bankname});
    </insert>
</mapper>