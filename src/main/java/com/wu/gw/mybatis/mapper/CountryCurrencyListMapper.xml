  <select id="getCountryCurrencyList" resultMap="BaseResultMap" parameterType="java.lang.String" >
    select *
    from das_countrycurrency_list
    where list_name = #{listName}
  </select>
  
  <insert id="addCountryCurrencyList" parameterType="com.wu.gw.mybatis.model.CountryCurrencyList" >
    insert into das_countrycurrency_list (list_name, s_country, s_currency, s_naid, update_time)
    values (#{listName}, #{sCountry}, #{sCurrency}, #{sNaid}, #{updateTime})
  </insert>

  <update id="updateCountryCurrencyListByListName" parameterType="com.wu.gw.mybatis.model.CountryCurrencyList" >
    update das_countrycurrency_list
    set update_time = #{updateTime}
    where list_name = #{listName}
  </update>

