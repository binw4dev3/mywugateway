    <result column="list_name" property="listName" jdbcType="VARCHAR" />
    <result column="s_country" property="sCountry" jdbcType="CHAR" />
    <result column="s_currency" property="sCurrency" jdbcType="CHAR" />
    <result column="s_naid" property="sNaid" jdbcType="CHAR" />
    <result column="update_time" property="updateTime" jdbcType="TIMESTAMP" />
  </resultMap>
